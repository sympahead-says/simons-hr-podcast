# 1Password Referenzen fuer lokale Entwicklung
# Verwendet von: scripts/dev.sh via `op read`
# Vault: "Dev Secrets privat" (my.1password.eu)
#
# Items in 1Password anlegen falls noch nicht vorhanden:
#   - Item "HR Podcast" mit Feldern "Anthropic API Key" und "GCP API Key"
#   - Oder bestehende Items referenzieren und Pfade in scripts/dev.sh anpassen
ANTHROPIC_API_KEY=op://Dev Secrets privat/HR Podcast/Anthropic API Key
GCP_API_KEY=op://Dev Secrets privat/HR Podcast/GCP API Key
